{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-task-list-app",
  "version": "0.3.0",
  "identifier": "com.dan.claude-task-list-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claude Task List",
        "width": 380,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "windowEffects": {
          "effects": ["hudWindow"],
          "state": "active",
          "radius": 12.0
        }
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "files": {
        "Resources/Assets.car": "./gen/macos/Assets.car"
      },
      "minimumSystemVersion": "",
      "signingIdentity": "Developer ID Application: OFFLIGHT Inc. (3V648FU6PC)"
    }
  }
}
